def proxima_maior_palavra(w):
    letras = list(w)
    tamanho = len(letras)
    
    i = tamanho - 2
    while i >= 0 and letras[i] >= letras[i + 1]:
        i -= 1
        
    if i == -1:
        return "no answer"
        
    j = tamanho - 1
    while letras[j] <= letras[i]:
        j -= 1
        
    temp = letras[i]
    letras[i] = letras[j]
    letras[j] = temp
    
    esquerda = i + 1
    direita = tamanho - 1
    while esquerda < direita:
        temp = letras[esquerda]
        letras[esquerda] = letras[direita]
        letras[direita] = temp
        esquerda += 1
        direita -= 1
        
    palavra_final = "".join(letras)
    return palavra_final

